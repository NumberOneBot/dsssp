{
  "name": "dsssp",
  "type": "module",
  "private": false,
  "version": "0.7.1",
  "author": "Oleksiy Strelets",
  "license": "MIT",
  "homepage": "https://dsssp.io",
  "description": "React components for audio equalizers and filter visualization: SVG frequency-response graphs, interactive biquad filters, and Web Audio curve math.",
  "funding": "https://github.com/numberonebot/dsssp?sponsor=1",
  "bugs": {
    "url": "https://github.com/numberonebot/dsssp/issues"
  },
  "keywords": [
    "react",
    "react-components",
    "typescript",
    "svg",
    "audio",
    "web-audio",
    "web-audio-api",
    "audio-visualization",
    "dsp",
    "digital-signal-processing",
    "equalizer",
    "eq",
    "parametric-eq",
    "biquad",
    "filter",
    "filters",
    "frequency-response",
    "bode-plot",
    "spectrum",
    "waveform",
    "graph",
    "visualization",
    "daw",
    "sound"
  ],
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./font": {
      "import": {
        "types": "./dist/font.d.ts",
        "default": "./dist/index.css"
      },
      "require": {
        "types": "./dist/font.d.ts",
        "default": "./dist/index.css"
      }
    }
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "build:lib": "vite build",
    "lint": "tsc && eslint .",
    "lint:fix": "eslint . --fix",
    "lint:complexity": "eslintcc -sr -a -mr=F -mar=F -gt=B \"./src/**/*.{ts,tsx}\"",
    "format": "prettier . --write --ignore-unknown",
    "prepare": "husky",
    "deps": "npx taze",
    "deps:update": "npx taze -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "version-minor": "npm version minor",
    "version-patch": "npm version patch",
    "version-prepatch": "npm version prepatch --preid=alpha",
    "publish": "npm publish",
    "publish:alpha": "npm publish --tag alpha"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/reddit-mono": "^5.2.8",
    "@fontsource/iosevka-etoile": "^5.2.5",
    "@fontsource/monaspace-krypton": "^5.2.5",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/builder-vite": "^10.5.0",
    "@storybook/react": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "clsx": "^2.1.1",
    "deepmerge": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.5.0",
    "eslintcc": "^0.8.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.5.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  }
}
